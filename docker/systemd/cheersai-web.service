[Unit]
Description=CheersAI Web Service
After=network.target

[Service]
User=cheersai
Group=cheersai
WorkingDirectory=/home/cheersai/CheersAI-Desktop/web
EnvironmentFile=/home/cheersai/CheersAI-Desktop/web/.env
# 注意：Next.js 生产环境运行需要 PORT 环境变量
Environment=PORT=3000
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm start
Restart=always

[Install]
WantedBy=multi-user.target

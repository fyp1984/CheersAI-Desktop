# === 基础安全配置 ===
# 请在服务器上生成一个新的密钥: openssl rand -base64 42
SECRET_KEY=Please_Change_Me_To_A_Strong_Random_String

# === 服务 URL 配置 (适配子路径 /cheersai_desktop) ===
CONSOLE_API_URL=https://desktop.cheersai.cloud/cheersai_desktop/console/api
CONSOLE_WEB_URL=https://desktop.cheersai.cloud/cheersai_desktop
SERVICE_API_URL=https://desktop.cheersai.cloud/cheersai_desktop/api
APP_WEB_URL=https://desktop.cheersai.cloud/cheersai_desktop
FILES_URL=https://desktop.cheersai.cloud/cheersai_desktop/files
INTERNAL_FILES_URL=http://127.0.0.1:8080

# === 数据库配置 ===
DB_TYPE=postgresql
DB_USERNAME=cheersai
DB_PASSWORD=ChangeMe123
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cheersai

# === Redis 配置 ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USE_SSL=false

# Celery (使用 Redis)
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_BACKEND=redis

# === 向量数据库 (Weaviate) ===
VECTOR_STORE=weaviate
WEAVIATE_ENDPOINT=http://127.0.0.1:8081
WEAVIATE_API_KEY=
WEAVIATE_GRPC_ENABLED=false

# === 文件存储 (本地) ===
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/home/cheersai/data/storage

# === 其他配置 ===
LOG_FILE=/home/cheersai/logs/api.log
LOG_LEVEL=INFO
DEBUG=false

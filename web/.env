# === 部署环境 ===
NEXT_PUBLIC_DEPLOY_ENV=PRODUCTION
NEXT_PUBLIC_EDITION=SELF_HOSTED

# === 基础路径 ===
# 关键：设置子路径，与 Nginx 配置一致
NEXT_PUBLIC_BASE_PATH=/cheersai_desktop

# === API 连接 (关键修改) ===
# 使用相对路径，浏览器会自动基于当前访问的域名/IP 进行拼接
# 例如访问 https://62.234.210.100/cheersai_desktop
# API 请求会自动变为 https://62.234.210.100/cheersai_desktop/console/api
# 这样可以完美适配 IP 访问和域名访问，解决 ERR_CONNECTION_CLOSED 问题
NEXT_PUBLIC_API_PREFIX=/cheersai_desktop/console/api
NEXT_PUBLIC_PUBLIC_API_PREFIX=/cheersai_desktop/api

# === 市场配置 ===
NEXT_PUBLIC_MARKETPLACE_API_PREFIX=https://marketplace.dify.ai/api/v1
NEXT_PUBLIC_MARKETPLACE_URL_PREFIX=https://marketplace.dify.ai

